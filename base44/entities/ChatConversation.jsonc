{
  "name": "ChatConversation",
  "type": "object",
  "properties": {
    "participants": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of participant emails"
    },
    "name": {
      "type": "string",
      "description": "Conversation name (for groups or custom names)"
    },
    "is_group": {
      "type": "boolean",
      "default": false
    },
    "group_photo": {
      "type": "string"
    },
    "last_message": {
      "type": "string"
    },
    "last_message_time": {
      "type": "string",
      "format": "date-time"
    },
    "last_message_sender": {
      "type": "string"
    },
    "unread_count": {
      "type": "object",
      "description": "Unread count per participant email",
      "default": {}
    },
    "type": {
      "type": "string",
      "enum": [
        "general",
        "ride",
        "booking",
        "order",
        "support"
      ],
      "default": "general"
    },
    "reference_id": {
      "type": "string",
      "description": "ID of related order/booking/ride"
    },
    "muted_by": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [],
      "description": "Emails of users who muted this conversation"
    },
    "pinned_by": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [],
      "description": "Emails of users who pinned this conversation"
    }
  },
  "required": [
    "participants"
  ],
  "rls": {
    "create": {},
    "read": {
      "participants": "{{user.email}}"
    },
    "update": {
      "participants": "{{user.email}}"
    },
    "delete": {
      "participants": "{{user.email}}"
    }
  }
}