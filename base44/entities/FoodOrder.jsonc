{
  "name": "FoodOrder",
  "type": "object",
  "properties": {
    "restaurant_id": {
      "type": "string"
    },
    "restaurant_name": {
      "type": "string"
    },
    "restaurant_address": {
      "type": "string",
      "description": "Pickup address for driver"
    },
    "restaurant_owner_email": {
      "type": "string",
      "description": "Restaurant owner email for notifications"
    },
    "restaurant_phone": {
      "type": "string"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "menu_item_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "price": {
            "type": "number"
          },
          "quantity": {
            "type": "number"
          }
        }
      }
    },
    "subtotal": {
      "type": "number"
    },
    "delivery_fee": {
      "type": "number"
    },
    "commission_amount": {
      "type": "number",
      "description": "Platform commission (10-15% of subtotal)"
    },
    "total": {
      "type": "number"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "confirmed",
        "preparing",
        "ready",
        "picked_up",
        "on_the_way",
        "delivered",
        "cancelled"
      ],
      "default": "pending"
    },
    "delivery_address": {
      "type": "string"
    },
    "delivery_coords": {
      "type": "array",
      "items": {
        "type": "number"
      }
    },
    "driver_email": {
      "type": "string"
    },
    "driver_name": {
      "type": "string"
    },
    "special_instructions": {
      "type": "string"
    },
    "estimated_delivery_time": {
      "type": "string"
    },
    "actual_delivery_time": {
      "type": "string",
      "format": "date-time"
    },
    "payment_intent_id": {
      "type": "string"
    },
    "delivery_order_id": {
      "type": "string",
      "description": "Linked DeliveryOrder id for driver dispatch"
    },
    "delivery_photo_url": {
      "type": "string",
      "description": "Proof-of-delivery photo uploaded by driver"
    },
    "payment_settled": {
      "type": "boolean",
      "default": false,
      "description": "Whether driver payment has been settled"
    },
    "driver_earnings": {
      "type": "number",
      "description": "Amount earned by driver for this order"
    }
  },
  "required": [
    "restaurant_id",
    "items",
    "total",
    "delivery_address"
  ],
  "rls": {
    "create": {
      "created_by": "{{user.email}}"
    },
    "read": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "driver_email": "{{user.email}}"
        },
        {
          "restaurant_owner_email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "driver_email": "{{user.email}}"
        },
        {
          "restaurant_owner_email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}